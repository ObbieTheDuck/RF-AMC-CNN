<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>RF Robust AMC CNN | Automatic Modulation Classification</title>
  <meta
    name="description"
    content="Research project on RF automatic modulation classification using a CNN trained on raw I/Q signal data under noisy SNR channel conditions."
  />

  <style>
    :root {
      --bg: #07111f;
      --panel: #101b2d;
      --panel-2: #132238;
      --text: #edf5ff;
      --muted: #a8b7ca;
      --accent: #48b7ff;
      --accent-2: #7c3aed;
      --good: #25d0ab;
      --warning: #fbbf24;
      --danger: #fb7185;
      --border: rgba(255, 255, 255, 0.12);
      --shadow: 0 20px 60px rgba(0, 0, 0, 0.35);
    }

    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
      scroll-behavior: smooth;
    }

    body {
      font-family: Arial, Helvetica, sans-serif;
      background:
        radial-gradient(circle at top left, rgba(72, 183, 255, 0.18), transparent 35%),
        radial-gradient(circle at top right, rgba(124, 58, 237, 0.18), transparent 35%),
        var(--bg);
      color: var(--text);
      line-height: 1.65;
    }

    a {
      color: inherit;
      text-decoration: none;
    }

    .container {
      width: min(1120px, calc(100% - 40px));
      margin: 0 auto;
    }

    .nav {
      position: sticky;
      top: 0;
      z-index: 20;
      background: rgba(7, 17, 31, 0.88);
      backdrop-filter: blur(14px);
      border-bottom: 1px solid var(--border);
    }

    .nav-inner {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 20px;
      padding: 16px 0;
    }

    .brand {
      display: flex;
      align-items: center;
      gap: 10px;
      font-weight: 800;
      letter-spacing: 0.3px;
    }

    .brand-mark {
      width: 34px;
      height: 34px;
      display: grid;
      place-items: center;
      border-radius: 10px;
      background: linear-gradient(135deg, var(--accent), var(--accent-2));
      box-shadow: 0 10px 30px rgba(72, 183, 255, 0.25);
      font-size: 0.85rem;
    }

    .nav-links {
      display: flex;
      align-items: center;
      gap: 18px;
      color: var(--muted);
      font-size: 0.95rem;
      flex-wrap: wrap;
      justify-content: flex-end;
    }

    .nav-links a:hover {
      color: var(--text);
    }

    .hero {
      padding: 88px 0 58px;
    }

    .hero-grid {
      display: grid;
      grid-template-columns: 1.15fr 0.85fr;
      gap: 34px;
      align-items: center;
    }

    .eyebrow {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 8px 12px;
      border: 1px solid var(--border);
      background: rgba(255, 255, 255, 0.06);
      border-radius: 999px;
      color: var(--muted);
      font-size: 0.9rem;
      margin-bottom: 20px;
    }

    .pulse {
      width: 9px;
      height: 9px;
      border-radius: 999px;
      background: var(--good);
      box-shadow: 0 0 0 6px rgba(37, 208, 171, 0.12);
    }

    h1 {
      font-size: clamp(2.4rem, 6vw, 5rem);
      line-height: 1.02;
      letter-spacing: -2px;
      margin-bottom: 22px;
    }

    .gradient-text {
      background: linear-gradient(135deg, #ffffff, #74d2ff 48%, #c4b5fd);
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
    }

    .hero-text {
      color: var(--muted);
      font-size: 1.12rem;
      max-width: 720px;
      margin-bottom: 28px;
    }

    .button-row {
      display: flex;
      gap: 14px;
      flex-wrap: wrap;
    }

    .button {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      padding: 12px 18px;
      border-radius: 12px;
      font-weight: 700;
      border: 1px solid var(--border);
      transition: transform 0.2s ease, border-color 0.2s ease, background 0.2s ease;
    }

    .button:hover {
      transform: translateY(-2px);
      border-color: rgba(255, 255, 255, 0.32);
    }

    .button.primary {
      background: linear-gradient(135deg, var(--accent), var(--accent-2));
      color: white;
      border: none;
    }

    .button.secondary {
      background: rgba(255, 255, 255, 0.06);
      color: var(--text);
    }

    .hero-card {
      background: linear-gradient(180deg, rgba(255, 255, 255, 0.1), rgba(255, 255, 255, 0.04));
      border: 1px solid var(--border);
      border-radius: 28px;
      padding: 28px;
      box-shadow: var(--shadow);
    }

    .signal-box {
      background: #06101c;
      border: 1px solid var(--border);
      border-radius: 22px;
      padding: 22px;
      overflow: hidden;
    }

    .wave {
      height: 150px;
      border-radius: 16px;
      background:
        linear-gradient(90deg, rgba(72, 183, 255, 0.12) 1px, transparent 1px),
        linear-gradient(rgba(255, 255, 255, 0.08) 1px, transparent 1px);
      background-size: 24px 24px;
      position: relative;
      margin-bottom: 18px;
    }

    .wave svg {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
    }

    .mini-stats {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 12px;
    }

    .mini-stat {
      background: rgba(255, 255, 255, 0.06);
      border: 1px solid var(--border);
      border-radius: 16px;
      padding: 14px;
    }

    .mini-stat strong {
      display: block;
      font-size: 1.35rem;
      line-height: 1;
      margin-bottom: 6px;
    }

    .mini-stat span {
      color: var(--muted);
      font-size: 0.82rem;
    }

    section {
      padding: 58px 0;
    }

    .section-title {
      max-width: 780px;
      margin-bottom: 28px;
    }

    .section-title h2 {
      font-size: clamp(1.8rem, 4vw, 3rem);
      margin-bottom: 12px;
      line-height: 1.1;
      letter-spacing: -1px;
    }

    .section-title p {
      color: var(--muted);
      font-size: 1.05rem;
    }

    .grid-3 {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 18px;
    }

    .grid-2 {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 18px;
    }

    .card {
      background: rgba(255, 255, 255, 0.065);
      border: 1px solid var(--border);
      border-radius: 22px;
      padding: 24px;
      box-shadow: 0 12px 34px rgba(0, 0, 0, 0.22);
    }

    .card h3 {
      font-size: 1.22rem;
      margin-bottom: 10px;
    }

    .card p,
    .card li {
      color: var(--muted);
    }

    .icon {
      width: 42px;
      height: 42px;
      display: grid;
      place-items: center;
      border-radius: 14px;
      background: rgba(72, 183, 255, 0.12);
      border: 1px solid rgba(72, 183, 255, 0.28);
      margin-bottom: 16px;
      font-weight: 800;
      color: #9ee2ff;
    }

    .workflow {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 14px;
      margin-top: 26px;
    }

    .step {
      position: relative;
      background: linear-gradient(180deg, rgba(72, 183, 255, 0.1), rgba(255, 255, 255, 0.04));
      border: 1px solid var(--border);
      border-radius: 20px;
      padding: 22px;
      min-height: 150px;
    }

    .step-number {
      display: inline-grid;
      place-items: center;
      width: 32px;
      height: 32px;
      border-radius: 999px;
      background: var(--accent);
      color: #04111d;
      font-weight: 800;
      margin-bottom: 18px;
    }

    .step h3 {
      margin-bottom: 8px;
    }

    .step p {
      color: var(--muted);
      font-size: 0.95rem;
    }

    .data-table,
    .matrix {
      width: 100%;
      border-collapse: collapse;
      overflow: hidden;
      border-radius: 16px;
      font-size: 0.95rem;
    }

    .data-table th,
    .data-table td,
    .matrix th,
    .matrix td {
      padding: 12px 14px;
      border-bottom: 1px solid var(--border);
      text-align: left;
    }

    .data-table th,
    .matrix th {
      color: white;
      background: rgba(255, 255, 255, 0.08);
    }

    .data-table td,
    .matrix td {
      color: var(--muted);
    }

    .matrix td {
      text-align: center;
    }

    .matrix .diag {
      color: var(--good);
      font-weight: 800;
      background: rgba(37, 208, 171, 0.08);
    }

    .chart {
      display: grid;
      gap: 12px;
      margin-top: 10px;
    }

    .bar-row {
      display: grid;
      grid-template-columns: 60px 1fr 52px;
      gap: 12px;
      align-items: center;
      color: var(--muted);
      font-size: 0.92rem;
    }

    .bar-track {
      height: 14px;
      background: rgba(255, 255, 255, 0.08);
      border-radius: 999px;
      overflow: hidden;
      border: 1px solid var(--border);
    }

    .bar-fill {
      height: 100%;
      border-radius: 999px;
      background: linear-gradient(90deg, var(--danger), var(--warning), var(--good));
    }

    .tag-list {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      margin-top: 14px;
    }

    .tag {
      padding: 7px 10px;
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.07);
      color: var(--muted);
      border: 1px solid var(--border);
      font-size: 0.9rem;
    }

    .code-block {
      background: #050b13;
      color: #dcecff;
      border: 1px solid var(--border);
      border-radius: 18px;
      padding: 18px;
      overflow-x: auto;
      font-family: Consolas, Monaco, monospace;
      font-size: 0.92rem;
      line-height: 1.6;
    }

    .team {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 18px;
    }

    .person {
      text-align: center;
    }

    .avatar {
      width: 72px;
      height: 72px;
      display: grid;
      place-items: center;
      margin: 0 auto 14px;
      border-radius: 24px;
      background: linear-gradient(135deg, var(--accent), var(--accent-2));
      font-weight: 900;
      font-size: 1.1rem;
      box-shadow: 0 16px 34px rgba(72, 183, 255, 0.2);
    }

    .footer {
      padding: 42px 0;
      border-top: 1px solid var(--border);
      color: var(--muted);
      text-align: center;
    }

    .note {
      border-left: 4px solid var(--accent);
      padding: 16px 18px;
      background: rgba(72, 183, 255, 0.08);
      border-radius: 14px;
      color: var(--muted);
    }

    @media (max-width: 900px) {
      .hero-grid,
      .grid-2,
      .grid-3,
      .workflow,
      .team {
        grid-template-columns: 1fr;
      }

      .nav-inner {
        align-items: flex-start;
        flex-direction: column;
      }

      .mini-stats {
        grid-template-columns: 1fr;
      }
    }
  </style>
</head>
