  <main id="top">
    <header class="hero">
      <div class="container hero-grid">
        <div>
          <div class="eyebrow"><span class="pulse"></span> ECE 4990.01 · Deep Learning Research Project</div>
          <h1><span class="gradient-text">Robust CNN-Based RF Automatic Modulation Classification</span></h1>
          <p class="hero-text">
            A deep learning project that classifies RF modulation types directly from raw I/Q signal data and evaluates how well a convolutional neural network performs under noisy channel conditions.
          </p>
